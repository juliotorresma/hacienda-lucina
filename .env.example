# ============================================================
# Variables de entorno — Hacienda Lucina
# ============================================================
# Copia este archivo a ".env" para correr scripts localmente
# (p. ej. el seed). En produccion, configura estas variables en
# Vercel (Project Settings -> Environment Variables).
#
# OJO: SUPABASE_URL y SUPABASE_ANON_KEY tambien viven en
# supabase-config.js porque son publicas por diseno.
# El resto son SECRETAS y NO deben exponerse al cliente.
# ============================================================

# Supabase (Project Settings -> API)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# JWT Secret (Project Settings -> API -> JWT Settings). Firma el token de sesion.
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET

# Meta WhatsApp Cloud API
META_WHATSAPP_TOKEN=YOUR_META_PERMANENT_TOKEN
META_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
META_OTP_TEMPLATE=hacienda_otp
META_EVENT_TEMPLATE=hacienda_evento
META_CONTACT_TEMPLATE=hacienda_contacto
META_TEMPLATE_LANG=es_MX
# Numero del dueno que recibe las solicitudes del formulario (E.164)
OWNER_WHATSAPP_PHONE=+528712832271

# EVENT_WEBHOOK_SECRET: lo eliges tu; se manda como header x-webhook-secret
#   en el Database Webhook de Supabase (notificacion de eventos).
EVENT_WEBHOOK_SECRET=YOUR_RANDOM_SHARED_SECRET

# OTP / sesion (opcionales)
# OTP_TTL_SECONDS=300        # vigencia del codigo OTP
# OTP_RESEND_SECONDS=30      # espera minima entre reenvios
# SESSION_TTL_SECONDS=43200  # vigencia de la sesion (12 h)
